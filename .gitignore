# 排除所有文件和文件夹
*

# 然后明确包含需要保留的部分
!/.gitignore

# 包含app目录及其内容
!/app/
!/app/*.py
!/app/__init__.py

# 包含tests目录及其内容
!/tests/
!/tests/*.py
!/tests/__init__.py

# 包含特定根目录文件
!/.env
!/README.md
!/requirements.txt
!/run.py

# 临时文件
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE和编辑器文件
.vscode/
.idea/
*.swp
*.swo

# 本地环境文件
.env.local
.env.development.local
.env.test.local
.env.production.local

# Python开发文件
.pytest_cache/
.python-version
venv/
env/
ENV/

# 编译文件
__pycache__/
*.pyc

# 日志文件
*.log

# macOS系统文件
.DS_Store

# Linux备份文件
*~